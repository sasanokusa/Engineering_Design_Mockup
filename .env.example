# Local School AI Minutes mock
# Copy this file to .env and adjust paths/URLs for your local Mac.

# App storage
LOCAL_SCHOOL_AI_DATA_DIR=./data
DATABASE_URL=sqlite:///./data/local_school_ai.db

# Open WebUI bridge
# Open WebUI should own the normal chat UI and call this backend as an external tool/API.
OPENWEBUI_BASE_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# LLM adapter
# Intended demo target: an OpenAI-compatible local server serving Gemma 4 E4B.
# For no-model UI/API smoke demos, set LLM_PROVIDER=mock.
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=local-dev-key
LLM_MODEL=gemma-4-e4b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ASR adapter
# Intended demo target: whisper.cpp. For no-model UI/API smoke demos, set ASR_PROVIDER=mock.
ASR_PROVIDER=whisper_cpp
ASR_MODEL_SIZE=base
ASR_LANGUAGE=ja
ASR_DEVICE=cpu
ASR_WHISPER_CPP_BINARY=whisper-cli
# Optional. If omitted, the app expects ./models/whisper/ggml-${ASR_MODEL_SIZE}.bin.
# ASR_MODEL_PATH=./models/whisper/ggml-base.bin
